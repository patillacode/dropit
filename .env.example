# Break-glass admin token: sign in at /admin with this to create users.
# Users are managed in the admin panel (a token is the login — no passwords).
# Generate one with: openssl rand -hex 32  (or: just admin-token)
# Also allows forever TTL and unlimited expiry on uploads.
ADMIN_TOKEN=your-secret-admin-token

# Allowed TTL values — add "forever" to enable permanent uploads (admin only)
ALLOWED_TTLS=1h,6h,24h,48h,7d

# Default TTL when not specified in upload request
DEFAULT_TTL=24h

# Maximum TTL for non-admin tokens (admin bypasses this limit)
MAX_USER_TTL=24h

# Max file upload size in bytes (default 5MB)
MAX_UPLOAD_SIZE=5242880

# Cleanup job interval in hours
CLEANUP_INTERVAL_HOURS=1

# Local data directory (Docker uses /data)
DATA_DIR=./data

# Domain for per-page share links — each page is served at {id}.{CONTENT_DOMAIN}
# In production, requires wildcard DNS (*.dropit.example.com) and SSL cert
CONTENT_DOMAIN=localhost:8000
