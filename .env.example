# Token list: name:token pairs, comma-separated
UPLOAD_TOKENS=alice:tok_abc123,bob:tok_xyz789

# Allowed TTL values (subset of: 1h,6h,24h,48h,7d)
ALLOWED_TTLS=1h,6h,24h,48h,7d

# Default TTL when not specified in upload request
DEFAULT_TTL=24h

# Max file upload size in bytes (default 5MB)
MAX_UPLOAD_SIZE=5242880

# Cleanup job interval in hours
CLEANUP_INTERVAL_HOURS=1

# Local data directory (Docker uses /data)
DATA_DIR=./data

# Base URL for generated share links
BASE_URL=http://localhost:52031
